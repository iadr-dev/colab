{
  "name": "@iadr-dev/colab",
  "version": "0.6.2",
  "description": "oh-my-colab (@iadr-dev/colab, CLI ohc): team-first AI coding workflows — methodology, orchestration, persistent memory; Claude Code plugin + Cursor/Codex/Gemini/Antigravity.",
  "keywords": [
    "oh-my-colab",
    "ohc",
    "iadr-dev",
    "claude-code",
    "claude-code-plugin",
    "cursor",
    "codex",
    "gemini",
    "antigravity",
    "ai-coding",
    "workflows",
    "tdd",
    "agents",
    "mcp",
    "orchestration",
    "persistent-memory"
  ],
  "license": "MIT",
  "bin": {
    "ohc": "scripts/ohc"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node tests/smoke/run-smoke.js",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:all": "npm test && vitest run",
    "test:shell": "bash tests/smoke/test-all.sh",
    "lint:skills": "node tests/smoke/check-skill-lines.js",
    "prepublishOnly": "npm test && npm run lint:skills",
    "version:check": "node scripts/version.js check",
    "version:fix": "node scripts/version.js fix",
    "version:set": "node scripts/version.js set",
    "version:bump": "node scripts/version.js bump",
    "version:bump:minor": "node scripts/version.js bump minor",
    "version:bump:major": "node scripts/version.js bump major",
    "version:tag": "node scripts/version.js tag",
    "version:current": "node scripts/version.js current",
    "version:changelog": "node scripts/version.js changelog"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iadr-dev/colab.git"
  },
  "homepage": "https://github.com/iadr-dev/colab#readme",
  "bugs": {
    "url": "https://github.com/iadr-dev/colab/issues"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^4.1.5"
  }
}
